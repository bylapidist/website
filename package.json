{
    "name": "@lapidist/website",
    "version": "0.0.0",
    "description": "The Lapidist website living at lapidist.net",
    "author": "Brett Dorrans <hello@lapidist.net>",
    "license": "MIT",
    "private": true,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bylapidist/website.git"
    },
    "bugs": {
        "url": "https://github.com/bylapidist/website/issues"
    },
    "homepage": "https://github.com/bylapidist/website#readme",
    "scripts": {
        "knip": "knip",
        "dev": "concurrently \"pnpm run build:tokens:watch\" \"next dev --turbopack\"",
        "start": "pnpm dlx serve@latest out",
        "start:server": "next start",
        "build": "pnpm run build:tokens && pnpm run build:cv && next build",
        "export": "next export",
        "build:cv": "node ./node_modules/@lapidist/cv-generator/dist/es5/cli.js && node -e \"require('fs').renameSync('brett-dorrans-cv.pdf','public/brett-dorrans-cv.pdf')\"",
        "build:static": "pnpm run build && pnpm run export",
        "build:tokens": "style-dictionary build --config style-dictionary.config.mjs && prettier styles/tokens.css --write",
        "build:tokens:watch": "node scripts/build-tokens-watch.mjs",
        "postbuild": "tsx scripts/fix-css-script-tags.ts",
        "lint": "pnpm run lint:js && pnpm run lint:styles",
        "lint:js": "eslint .",
        "lint:styles": "stylelint \"**/*.{css,scss}\" --ignore-path .gitignore",
        "format": "prettier . --check --plugin=@ianvs/prettier-plugin-sort-imports",
        "format:write": "prettier . --write --plugin=@ianvs/prettier-plugin-sort-imports",
        "typecheck": "tsc --noEmit",
        "fix": "pnpm run lint:js -- --fix && pnpm run lint:styles -- --fix && pnpm run format:write",
        "test": "pnpm run test:unit && pnpm run test:e2e",
        "test:unit": "vitest run",
        "test:e2e": "playwright test",
        "test:install-browsers": "playwright install --with-deps"
    },
    "dependencies": {
        "@floating-ui/react": "0.27.20",
        "@fontsource-variable/mona-sans": "^5.2.8",
        "@lapidist/cv-generator": "2.8.4",
        "clsx": "2.1.1",
        "feed": "5.2.1",
        "github-slugger": "2.0.0",
        "gray-matter": "4.0.3",
        "mdast-util-to-string": "4.0.0",
        "next": "16.2.10",
        "next-mdx-remote": "6.0.0",
        "prettier": "3.9.5",
        "prismjs": "1.30.0",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "rehype-prism-plus": "2.0.2",
        "remark": "15.0.1",
        "remark-gfm": "4.0.1",
        "remark-reading-time": "2.1.0",
        "server-only": "0.0.1",
        "unist-util-visit": "5.1.0",
        "wavesurfer.js": "7.12.10"
    },
    "devDependencies": {
        "@axe-core/playwright": "4.12.1",
        "@eslint/core": "1.2.1",
        "@eslint/js": "10.0.1",
        "@ianvs/prettier-plugin-sort-imports": "4.7.1",
        "@next/eslint-plugin-next": "16.2.10",
        "@playwright/test": "1.61.1",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@testing-library/user-event": "14.6.1",
        "@types/mdast": "4.0.4",
        "@types/node": "26.1.1",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "@types/unist": "3.0.3",
        "concurrently": "10.0.3",
        "eslint": "10.7.0",
        "eslint-config-next": "16.2.10",
        "eslint-import-resolver-typescript": "4.4.5",
        "eslint-plugin-import": "2.32.0",
        "eslint-plugin-jsx-a11y": "6.10.2",
        "eslint-plugin-react-compiler": "19.1.0-rc.2",
        "jsdom": "29.1.1",
        "knip": "6.26.0",
        "postcss-import": "16.1.1",
        "postcss-scss": "4.0.9",
        "sass": "1.101.0",
        "style-dictionary": "5.5.0",
        "stylelint": "17.14.0",
        "stylelint-config-css-modules": "4.6.0",
        "stylelint-config-standard": "40.0.0",
        "tsx": "4.23.1",
        "typescript": "6.0.3",
        "typescript-eslint": "8.64.0",
        "vite": "8.1.5",
        "vitest": "4.1.10"
    },
    "packageManager": "pnpm@11.14.0"
}
