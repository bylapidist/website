{
    "name": "@lapidist/website",
    "version": "0.0.0",
    "description": "The Lapidist website living at lapidist.net",
    "author": "Brett Dorrans <hello@lapidist.net>",
    "license": "MIT",
    "private": true,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bylapidist/website.git"
    },
    "bugs": {
        "url": "https://github.com/bylapidist/website/issues"
    },
    "homepage": "https://github.com/bylapidist/website#readme",
    "scripts": {
        "dev": "concurrently \"pnpm run build:tokens:watch\" \"next dev --turbopack\"",
        "start": "pnpm dlx serve@latest out",
        "start:server": "next start",
        "build": "pnpm run build:tokens && pnpm run build:cv && next build",
        "export": "next export",
        "build:cv": "node ./node_modules/@lapidist/cv-generator/dist/es5/cli.js && node -e \"require('fs').renameSync('brett-dorrans-cv.pdf','public/brett-dorrans-cv.pdf')\"",
        "build:static": "pnpm run build && pnpm run export",
        "build:tokens": "style-dictionary build --config style-dictionary.config.mjs && prettier styles/tokens.css --write",
        "build:tokens:watch": "node scripts/build-tokens-watch.mjs",
        "postbuild": "tsx scripts/fix-css-script-tags.ts",
        "lint": "pnpm run lint:js && pnpm run lint:styles",
        "lint:js": "eslint .",
        "lint:styles": "stylelint \"**/*.{css,scss}\" --ignore-path .gitignore",
        "format": "prettier . --check --plugin=@ianvs/prettier-plugin-sort-imports",
        "format:write": "prettier . --write --plugin=@ianvs/prettier-plugin-sort-imports",
        "typecheck": "tsc --noEmit",
        "fix": "pnpm run lint:js -- --fix && pnpm run lint:styles -- --fix && pnpm run format:write",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "test:storybook": "pnpm run build-storybook && start-server-and-test 'pnpm dlx http-server storybook-static -p 6006' http://127.0.0.1:6006 'test-storybook --ci --url http://127.0.0.1:6006'",
        "test": "pnpm run test:unit && pnpm run test:e2e",
        "test:unit": "vitest run",
        "test:e2e": "playwright test",
        "test:install-browsers": "playwright install --with-deps",
        "lh:ci": "lhci autorun --config=.lighthouserc.json --enable-error-reporting=false",
        "preqa": "pnpm run build",
        "qa": "start-server-and-test start http://localhost:3000 lh:ci"
    },
    "dependencies": {
        "@floating-ui/react": "0.27.19",
        "@lapidist/cv-generator": "2.8.2",
        "clsx": "2.1.1",
        "feed": "5.2.1",
        "github-slugger": "2.0.0",
        "gray-matter": "4.0.3",
        "mdast-util-to-string": "4.0.0",
        "next": "16.1.7",
        "next-mdx-remote": "5.0.0",
        "prettier": "3.8.2",
        "prismjs": "1.30.0",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "rehype-prism-plus": "2.0.2",
        "remark": "15.0.1",
        "remark-gfm": "4.0.1",
        "remark-reading-time": "2.1.0",
        "server-only": "0.0.1",
        "unist-util-visit": "5.1.0",
        "wavesurfer.js": "7.12.6"
    },
    "devDependencies": {
        "@axe-core/playwright": "4.11.2",
        "@eslint/eslintrc": "3.3.5",
        "@eslint/js": "9.39.4",
        "@ianvs/prettier-plugin-sort-imports": "4.7.1",
        "@lhci/cli": "0.15.1",
        "@next/eslint-plugin-next": "16.2.3",
        "@playwright/test": "1.59.1",
        "@storybook/addon-a11y": "10.3.5",
        "@storybook/addon-docs": "10.3.5",
        "@storybook/test-runner": "0.24.3",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@testing-library/user-event": "14.6.1",
        "@types/node": "25.6.0",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "concurrently": "9.2.1",
        "eslint": "9.39.4",
        "eslint-config-next": "16.2.3",
        "eslint-import-resolver-typescript": "4.4.4",
        "eslint-plugin-import": "2.32.0",
        "eslint-plugin-jsx-a11y": "6.10.2",
        "eslint-plugin-react-compiler": "19.1.0-rc.2",
        "eslint-plugin-storybook": "10.3.5",
        "jsdom": "27.4.0",
        "lighthouse": "13.1.0",
        "postcss-import": "16.1.1",
        "postcss-scss": "4.0.9",
        "sass": "1.99.0",
        "start-server-and-test": "2.1.5",
        "storybook": "10.3.5",
        "style-dictionary": "5.4.0",
        "stylelint": "16.26.1",
        "stylelint-config-css-modules": "4.6.0",
        "stylelint-config-standard": "39.0.1",
        "tsx": "4.21.0",
        "typescript": "5.9.3",
        "typescript-eslint": "8.58.1",
        "vite": "7.3.2",
        "vitest": "4.1.4",
        "@storybook/nextjs-vite": "10.3.5"
    },
    "packageManager": "pnpm@11.9.0"
}
